---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogArticles, postImageUrl } from '../../data/blog-articles';
import { markdownToBlogHtml, countWordsMarkdown, splitHtmlAtMidParagraph } from '../../data/render-blog-body';
import { siteConfig, whatsappHref } from '../../config';

export function getStaticPaths() {
  return blogArticles.map((a) => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const article = blogArticles.find((a) => a.slug === slug);

if (!article) {
  return Astro.redirect('/havaianas-personalizadas-blog');
}

const baseUrl = siteConfig.url.replace(/\/$/, '');
const canonical = `${baseUrl}/havaianas-personalizadas-blog/${article.slug}/`;
const fallbackOg = siteConfig.images.destaqueHavaianas;
const shareImage = postImageUrl(baseUrl, article.image ?? fallbackOg);
const ogImageAltResolved = article.imageAlt ?? 'Havaianas personalizadas — Chinelos da Bela';
const bodyHtml = markdownToBlogHtml(article.bodyMarkdown);
const { before: bodyBeforeMid, after: bodyAfterMid } = splitHtmlAtMidParagraph(bodyHtml);
const waArticle = whatsappHref(
  siteConfig.whatsappPhone,
  `Olá! Li o artigo "${article.title}" e quero um orçamento.`,
);
const wordCount = countWordsMarkdown(article.bodyMarkdown);
const metaDesc = article.metaDescription ?? article.excerpt;

const articleJsonLd: Record<string, unknown>[] = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Início', item: `${baseUrl}/` },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Blog da Bela',
        item: `${baseUrl}/havaianas-personalizadas-blog/`,
      },
      { '@type': 'ListItem', position: 3, name: article.title, item: canonical },
    ],
  },
  {
    '@type': 'BlogPosting',
    headline: article.title,
    description: metaDesc,
    image: shareImage,
    url: canonical,
    mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
    isPartOf: { '@id': `${baseUrl}/havaianas-personalizadas-blog/#blog` },
    author: { '@type': 'Organization', name: siteConfig.name },
    publisher: { '@id': `${baseUrl}/#organization` },
    inLanguage: 'pt-BR',
    wordCount,
    keywords: article.tag,
  },
];
---

<BaseLayout
  title={`${article.title} — Blog da Bela`}
  description={metaDesc}
  image={shareImage}
  ogImageAlt={ogImageAltResolved}
  jsonLdExtra={articleJsonLd}
>
  <article class="bela-section bela-section-muted py-12 md:py-16" itemscope itemtype="https://schema.org/Article">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <nav class="text-sm text-zinc-500 mb-8" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-2">
          <li>
            <a href="/" class="text-rose-300/90 hover:text-rose-200">Início</a>
          </li>
          <li aria-hidden="true">/</li>
          <li>
            <a href="/havaianas-personalizadas-blog" class="text-rose-300/90 hover:text-rose-200">Blog da Bela</a>
          </li>
          <li aria-hidden="true">/</li>
          <li class="text-zinc-400 truncate max-w-[min(100%,14rem)] sm:max-w-none">{article.title}</li>
        </ol>
      </nav>

      <header class="mb-10">
        <p class="text-xs font-medium text-rose-300 uppercase tracking-wide mb-3">{article.tag}</p>
        <h1 class="text-3xl md:text-4xl font-bold text-white leading-tight" itemprop="headline">
          {article.title}
        </h1>
        <p class="mt-4 text-zinc-400 leading-relaxed" itemprop="description">
          {article.excerpt}
        </p>
      </header>

      {
        article.image ? (
          <div class="-mx-1 mb-8 mx-auto max-w-lg overflow-hidden rounded-xl border border-white/10 bg-zinc-900/40 sm:max-w-xl">
            <img
              src={article.image}
              alt={article.imageAlt ?? ''}
              class="w-full h-auto object-cover"
              width="672"
              height="420"
              loading="eager"
              decoding="async"
              referrerpolicy="no-referrer"
            />
          </div>
        ) : null
      }

      <div
        class="bela-prose bela-blog-body space-y-4 text-zinc-300 leading-relaxed [&_h2]:text-xl [&_h2]:md:text-2xl [&_h2]:font-bold [&_h2]:text-white [&_h2]:mt-10 [&_h2]:mb-3 [&_h2]:font-display [&_h3]:text-lg [&_h3]:font-semibold [&_h3]:text-white [&_h3]:mt-6 [&_h3]:mb-2 [&_p]:mb-3 [&_p]:text-zinc-400 [&_p]:leading-relaxed [&_img]:mx-auto [&_img]:my-4 [&_img]:block [&_img]:h-auto [&_img]:w-full [&_img]:max-w-sm [&_img]:rounded-lg sm:[&_img]:max-w-md md:[&_img]:max-w-lg [&_img]:border [&_img]:border-white/10 [&_img]:shadow-md [&_img]:shadow-black/15 [&_ul]:my-4 [&_ul]:list-disc [&_ul]:pl-5 [&_ol]:my-4 [&_ol]:list-decimal [&_ol]:pl-5 [&_li]:mb-2 [&_li]:text-zinc-400 [&_strong]:font-semibold [&_strong]:text-zinc-200 [&_a]:text-rose-300 [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:text-rose-200 [&_blockquote]:my-4 [&_blockquote]:border-l-4 [&_blockquote]:border-rose-500/35 [&_blockquote]:pl-4 [&_blockquote]:text-zinc-500"
        itemprop="articleBody"
      >
        <div set:html={bodyBeforeMid} />
        {
          bodyAfterMid ? (
            <>
              <aside
                class="my-10 flex flex-col items-center gap-4 rounded-2xl border border-rose-500/25 bg-gradient-to-b from-rose-500/10 to-transparent px-4 py-8 text-center sm:px-8"
                aria-label="Solicitar orçamento"
              >
                <p class="max-w-md text-sm leading-relaxed text-zinc-400">
                  Quer levar isso para o seu evento? Peça um orçamento sem compromisso.
                </p>
                <a
                  href={waArticle}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex w-full min-h-[48px] max-w-md items-center justify-center rounded-full bg-[#e11d48] px-8 py-3 text-base font-bold text-white shadow-lg shadow-rose-950/40 transition-colors hover:bg-[#be123c] focus-visible:outline focus-visible:ring-2 focus-visible:ring-rose-400 focus-visible:ring-offset-2 focus-visible:ring-offset-[#111116] sm:w-auto"
                  aria-label="Solicitar orçamento no WhatsApp"
                >
                  Solicitar orçamento
                </a>
              </aside>
              <div set:html={bodyAfterMid} />
            </>
          ) : null
        }
      </div>

      <footer class="mt-14 pt-10 border-t border-white/10">
        <a
          href={waArticle}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex w-full min-h-[48px] items-center justify-center rounded-full bg-[#e11d48] px-8 py-3 text-base font-bold text-white shadow-lg shadow-rose-950/40 transition-colors hover:bg-[#be123c] focus-visible:outline focus-visible:ring-2 focus-visible:ring-rose-400 focus-visible:ring-offset-2 focus-visible:ring-offset-[#111116] sm:w-auto sm:min-w-[14rem]"
          aria-label="Solicitar orçamento no WhatsApp"
        >
          Solicitar orçamento
        </a>
        <p class="mt-8 text-sm text-zinc-500">
          Conteúdo no mesmo tema da página em{' '}
          <a href={article.originalUrl} class="text-rose-300 hover:underline" target="_blank" rel="noopener noreferrer">
            chinelosdabela.com.br
          </a>
          .
        </p>
        <p class="mt-6">
          <a href="/havaianas-personalizadas-blog" class="text-rose-300 text-sm font-medium hover:text-rose-200">
            ← Voltar ao blog
          </a>
        </p>
      </footer>
    </div>
  </article>
</BaseLayout>
