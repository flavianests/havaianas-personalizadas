---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogArticles, postImageUrl } from '../../data/blog-articles';
import { siteConfig, whatsappHref } from '../../config';

export function getStaticPaths() {
  return blogArticles.map((a) => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const article = blogArticles.find((a) => a.slug === slug);

if (!article) {
  return Astro.redirect('/blog');
}

const baseUrl = siteConfig.url.replace(/\/$/, '');
const canonical = `${baseUrl}/blog/${article.slug}/`;
const shareImage = postImageUrl(baseUrl, article.image);

const articleJsonLd: Record<string, unknown>[] = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Início', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Blog da Bela', item: `${baseUrl}/blog/` },
      { '@type': 'ListItem', position: 3, name: article.title, item: canonical },
    ],
  },
  {
    '@type': 'BlogPosting',
    headline: article.title,
    description: article.excerpt,
    image: shareImage,
    url: canonical,
    mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
    isPartOf: { '@id': `${baseUrl}/blog/#blog` },
    author: { '@type': 'Organization', name: siteConfig.name },
    publisher: { '@id': `${baseUrl}/#organization` },
    inLanguage: 'pt-BR',
  },
];
---

<BaseLayout
  title={`${article.title} — Blog da Bela`}
  description={article.excerpt}
  image={shareImage}
  ogImageAlt={article.imageAlt}
  jsonLdExtra={articleJsonLd}
>
  <article class="bela-section bela-section-muted py-12 md:py-16" itemscope itemtype="https://schema.org/Article">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <nav class="text-sm text-zinc-500 mb-8" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-2">
          <li>
            <a href="/" class="text-rose-300/90 hover:text-rose-200">Início</a>
          </li>
          <li aria-hidden="true">/</li>
          <li>
            <a href="/blog" class="text-rose-300/90 hover:text-rose-200">Blog da Bela</a>
          </li>
          <li aria-hidden="true">/</li>
          <li class="text-zinc-400 truncate max-w-[min(100%,14rem)] sm:max-w-none">{article.title}</li>
        </ol>
      </nav>

      <header class="mb-10">
        <p class="text-xs font-medium text-rose-300 uppercase tracking-wide mb-3">{article.tag}</p>
        <h1 class="text-3xl md:text-4xl font-bold text-white leading-tight" itemprop="headline">
          {article.title}
        </h1>
        <p class="mt-4 text-zinc-400 leading-relaxed" itemprop="description">
          {article.excerpt}
        </p>
      </header>

      <div class="-mx-1 mb-10 overflow-hidden rounded-2xl border border-white/10 bg-zinc-900/40">
        <img
          src={postImageUrl(baseUrl, article.image)}
          alt={article.imageAlt}
          class="w-full h-auto object-cover"
          width="1080"
          height="675"
          loading="eager"
          decoding="async"
          referrerpolicy="no-referrer"
        />
      </div>

      <div
        class="bela-prose bela-blog-body space-y-4 text-zinc-300 leading-relaxed [&_h2]:text-xl [&_h2]:md:text-2xl [&_h2]:font-bold [&_h2]:text-white [&_h2]:mt-10 [&_h2]:mb-3 [&_h2]:font-display [&_h3]:text-lg [&_h3]:font-semibold [&_h3]:text-white [&_h3]:mt-6 [&_h3]:mb-2 [&_p]:text-zinc-400"
        itemprop="articleBody"
      >
        {
          article.blocks.map((b) =>
            b.type === 'h2' ? (
              <h2>{b.text}</h2>
            ) : b.type === 'h3' ? (
              <h3>{b.text}</h3>
            ) : (
              <p>{b.text}</p>
            ),
          )
        }
      </div>

      <footer class="mt-14 pt-10 border-t border-white/10">
        <a
          href={whatsappHref(siteConfig.whatsappPhone, `Olá! Li o artigo "${article.title}" e quero um orçamento.`)}
          target="_blank"
          rel="noopener noreferrer"
          class="bela-cta-pulse-whatsapp inline-flex w-full sm:w-auto min-h-[52px] items-center justify-center gap-2 rounded-full bg-[#25D366] px-8 py-3.5 text-base font-semibold text-white hover:bg-[#20bd5a] transition-colors"
        >
          <i class="fab fa-whatsapp text-xl" aria-hidden="true" />
          Pedir orçamento no WhatsApp
        </a>
        <p class="mt-8 text-sm text-zinc-500">
          Conteúdo no mesmo tema da página em{' '}
          <a href={article.originalUrl} class="text-rose-300 hover:underline" target="_blank" rel="noopener noreferrer">
            chinelosdabela.com.br
          </a>
          .
        </p>
        <p class="mt-6">
          <a href="/blog" class="text-rose-300 text-sm font-medium hover:text-rose-200">← Voltar ao blog</a>
        </p>
      </footer>
    </div>
  </article>
</BaseLayout>
