---
import BaseLayout from '../layouts/BaseLayout.astro';
import NossosClientesCarousel from '../components/NossosClientesCarousel.astro';
import ClientesQueAtendemos from '../components/ClientesQueAtendemos.astro';
import { siteConfig, whatsappHref } from '../config';

const img = siteConfig.images;
const baseUrl = siteConfig.url.replace(/\/$/, '');
const metaDescription =
  'Havaianas Personalizadas para eventos: casamento, festa de 15 anos, formatura, aniversários e corporativos. Chinelos da Bela em São Paulo (Jd. Celeste): Havaianas originais, estampa no solado e orçamento pelo WhatsApp.';
const heroShareUrl = `${baseUrl}${img.heroHomeRio}`;

const homeJsonLd: Record<string, unknown>[] = [
  {
    '@type': 'WebPage',
    '@id': `${baseUrl}/#webpage`,
    url: `${baseUrl}/`,
    name: 'Havaianas Personalizadas para Eventos — Chinelos da Bela',
    description: metaDescription,
    isPartOf: { '@id': `${baseUrl}/#website` },
    inLanguage: 'pt-BR',
    primaryImageOfPage: {
      '@type': 'ImageObject',
      url: heroShareUrl,
    },
    mainEntity: {
      '@type': 'ItemList',
      name: 'Produtos de Havaianas Personalizadas para eventos',
      numberOfItems: 4,
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          item: {
            '@type': 'Service',
            name: 'Havaianas Personalizadas para casamento',
            description: 'Lembrancinhas personalizadas com sola Havaianas original para casamentos.',
            url: `${baseUrl}/produtos/casamento/`,
            provider: { '@id': `${baseUrl}/#localbusiness` },
            areaServed: 'BR',
          },
        },
        {
          '@type': 'ListItem',
          position: 2,
          item: {
            '@type': 'Service',
            name: 'Havaianas Personalizadas para formatura',
            description: 'Chinelos personalizados para formaturas e celebrações acadêmicas.',
            url: `${baseUrl}/produtos/formatura/`,
            provider: { '@id': `${baseUrl}/#localbusiness` },
            areaServed: 'BR',
          },
        },
        {
          '@type': 'ListItem',
          position: 3,
          item: {
            '@type': 'Service',
            name: 'Havaianas Personalizadas para festa de 15 anos',
            description: 'Havaianas com estampa no solado para debutantes e convidados.',
            url: `${baseUrl}/produtos/festa-15-anos/`,
            provider: { '@id': `${baseUrl}/#localbusiness` },
            areaServed: 'BR',
          },
        },
        {
          '@type': 'ListItem',
          position: 4,
          item: {
            '@type': 'Service',
            name: 'Havaianas Personalizadas para evento corporativo',
            description: 'Brindes e kits para convenções, feiras e eventos de marca com personalização profissional.',
            url: `${baseUrl}/produtos/eventos-corporativos/`,
            provider: { '@id': `${baseUrl}/#localbusiness` },
            areaServed: 'BR',
          },
        },
      ],
    },
  },
];
---

<BaseLayout
  title="Havaianas Personalizadas para Eventos — Chinelos da Bela"
  description={metaDescription}
  image={heroShareUrl}
  ogImageAlt="Havaianas Personalizadas em evento — cliente Chinelos da Bela, São Paulo"
  jsonLdExtra={homeJsonLd}
>
  <section
    class="bela-section relative flex min-h-[90vh] items-center overflow-hidden bg-[#111116]"
    aria-labelledby="titulo-principal-havaianas"
  >
    <div
      class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24 grid lg:grid-cols-[1fr_min(50%,560px)] gap-12 lg:gap-8 xl:gap-12 items-center"
    >
      <!-- Coluna esquerda: badge → H1 → texto → CTA → prova social -->
      <div class="text-left max-w-xl lg:max-w-none">
        <div
          class="inline-flex items-center rounded-full border border-white/15 bg-white/5 px-4 py-2 text-xs font-medium tracking-wide text-white/90 backdrop-blur-sm"
        >
          Do conceito à lembrança perfeita
        </div>
        <h1
          id="titulo-principal-havaianas"
          class="mt-5 text-3xl sm:text-4xl md:text-5xl lg:text-[2.65rem] xl:text-6xl font-bold leading-[1.08] tracking-tight"
        >
          <span class="bela-hero-h1-shine block">
            <span class="block">Havaianas Personalizadas com</span>
            <span class="block">Estampa de Alta Durabilidade</span>
          </span>
        </h1>
        <h2
          class="mt-4 max-w-3xl text-lg font-bold leading-snug text-white sm:text-xl md:text-2xl lg:text-[1.65rem] xl:text-[1.85rem] tracking-tight"
        >
          Casamentos, Festas de 15 anos, Formaturas, Aniversários e Eventos Corporativos - Atendemos São Paulo e todo o
          Brasil
        </h2>
        <p class="mt-6 text-base sm:text-lg text-white/75 leading-relaxed max-w-lg">
          Na Chinelos da Bela as suas Havaianas Personalizadas com estampa direto no solado — do casamento ao corporativo,
          passando por aniversários e festas.
        </p>
        <div class="mt-9 flex flex-wrap items-center gap-4">
          <a
            href={whatsappHref(siteConfig.whatsappPhone)}
            target="_blank"
            rel="noopener noreferrer"
            class="bela-cta-pulse-rose inline-flex min-h-[52px] items-center justify-center rounded-full bg-rose-600 px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-rose-900/40 transition hover:bg-rose-500"
            aria-label="Solicitar orçamento de Havaianas Personalizadas pelo WhatsApp"
          >
            Solicitar orçamento
          </a>
          <a
            href="/sobre"
            class="inline-flex min-h-[52px] items-center justify-center rounded-full border border-white/25 px-7 py-3.5 text-base font-medium text-white/90 transition hover:border-white/40 hover:bg-white/5"
            aria-label="Conheça a Chinelos da Bela — sobre Havaianas Personalizadas e a equipe"
          >
            Conheça a Chinelos da Bela
          </a>
        </div>

        <div class="mt-10 flex flex-wrap items-center gap-4">
          <div class="flex -space-x-3">
            <img
              src={img.heroHomeRio}
              alt="Havaianas Personalizadas com estampa Rio de Janeiro"
              class="bela-hero-collage-img h-11 w-11 rounded-full border-2 border-[#111116] object-cover object-center sm:h-12 sm:w-12"
              loading="lazy"
            />
            <img
              src={img.heroHomeArbit}
              alt="Caixa com Havaianas Personalizadas para evento corporativo"
              class="bela-hero-collage-img h-11 w-11 rounded-full border-2 border-[#111116] object-cover object-center sm:h-12 sm:w-12"
              loading="lazy"
            />
            <img
              src={img.heroHomeSemParar}
              alt="Havaianas Personalizadas Terça da Serra — solado com identidade no relevo"
              class="bela-hero-collage-img h-11 w-11 rounded-full border-2 border-[#111116] object-cover object-center sm:h-12 sm:w-12"
              loading="lazy"
            />
            <span
              class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full border-2 border-[#111116] bg-rose-600 text-xs font-bold text-white sm:h-12 sm:w-12"
              aria-hidden="true"
            >
              +
            </span>
          </div>
          <div>
            <div class="flex gap-0.5 text-amber-400" aria-label="Avaliação 5 estrelas">
              <i class="fas fa-star text-sm" aria-hidden="true"></i>
              <i class="fas fa-star text-sm" aria-hidden="true"></i>
              <i class="fas fa-star text-sm" aria-hidden="true"></i>
              <i class="fas fa-star text-sm" aria-hidden="true"></i>
              <i class="fas fa-star text-sm" aria-hidden="true"></i>
            </div>
            <p class="mt-1 text-sm font-medium text-white/80">Centenas de eventos realizados</p>
          </div>
        </div>
      </div>

      <!-- Coluna direita: colagem — molduras em gradiente + brilho ambiente -->
      <div class="relative mx-auto w-full max-w-[min(100%,480px)] lg:max-w-[600px] lg:mx-0 lg:justify-self-end">
        <div
          class="pointer-events-none absolute -inset-10 z-0 opacity-[0.85] sm:-inset-14"
          aria-hidden="true"
        >
          <div
            class="absolute left-[8%] top-[18%] h-[min(280px,55%)] w-[min(280px,70%)] rounded-full bg-rose-600/25 blur-[56px]"
          >
          </div>
          <div
            class="absolute right-0 top-[8%] h-[min(200px,40%)] w-[min(200px,45%)] rounded-full bg-cyan-400/20 blur-[48px]"
          >
          </div>
          <div
            class="absolute bottom-[12%] right-[15%] h-[min(220px,45%)] w-[min(220px,50%)] rounded-full bg-fuchsia-500/20 blur-[52px]"
          >
          </div>
        </div>
        <div class="relative z-10 mx-auto h-[520px] w-full sm:h-[560px] lg:h-[580px]">
          <div
            class="bela-hero-slot absolute left-0 top-2 z-30 sm:left-4"
            style="--enter-delay: 0.06s; --drift-rot: 17deg; --drift-delay: 0s; --drift-dur: 5.5s;"
          >
            <div class="bela-hero-float">
              <div
                class="bela-hero-card-frame bela-hero-card-frame--rio rounded-[1.85rem] rounded-br-[2.65rem] sm:rounded-[2rem] sm:rounded-br-[2.85rem] md:rounded-br-[3rem]"
              >
                <div
                  class="bela-hero-float-clip flex h-[300px] w-[230px] items-center justify-center rounded-[1.7rem] rounded-br-[2.45rem] bg-zinc-950 sm:h-[320px] sm:w-[248px] sm:rounded-[1.85rem] sm:rounded-br-[2.65rem] md:h-[340px] md:w-[260px] md:rounded-br-[2.85rem]"
                >
                  <img
                    src={img.heroHomeRio}
                    alt="Havaianas Personalizadas com estampa Rio de Janeiro e logos Capoeira Brasil e Festival GCB"
                    class="bela-hero-collage-img bela-hero-float-media bela-hero-float-media--contain block h-full w-full max-w-none object-contain object-center p-2"
                    loading="eager"
                    fetchpriority="high"
                  />
                </div>
              </div>
            </div>
          </div>
          <div
            class="bela-hero-slot absolute -right-1 top-12 z-20 sm:top-14 md:right-0"
            style="--enter-delay: 0.2s; --drift-rot: 19deg; --drift-delay: 1.1s; --drift-dur: 6.2s;"
          >
            <div class="bela-hero-float">
              <div
                class="bela-hero-card-frame bela-hero-card-frame--arbit rounded-[1.65rem] rounded-tl-[2.35rem] sm:rounded-[1.75rem] sm:rounded-tl-[2.55rem]"
              >
                <div
                  class="bela-hero-float-clip flex h-[240px] w-[190px] items-center justify-center rounded-[1.5rem] rounded-tl-[2.2rem] bg-zinc-950 sm:h-[260px] sm:w-[200px] sm:rounded-[1.6rem] sm:rounded-tl-[2.4rem]"
                >
                  <img
                    src={img.heroHomeArbit}
                    alt="Caixa com Havaianas Personalizadas — comemoração corporativa"
                    class="bela-hero-collage-img bela-hero-float-media bela-hero-float-media--contain block h-full w-full max-w-none object-contain object-center p-2"
                    loading="eager"
                  />
                </div>
              </div>
            </div>
          </div>
          <div
            class="bela-hero-slot absolute bottom-4 right-2 z-[28] sm:bottom-6 sm:right-4"
            style="--enter-delay: 0.48s; --drift-rot: 14deg; --drift-delay: 1.65s; --drift-dur: 6.8s;"
          >
            <div class="bela-hero-float">
              <div
                class="bela-hero-card-frame bela-hero-card-frame--sem-parar rounded-[1.5rem] rounded-tr-[2.4rem] sm:rounded-[1.65rem] sm:rounded-tr-[2.65rem]"
              >
                <div
                  class="bela-hero-float-clip flex h-[240px] w-[182px] items-center justify-center rounded-[1.35rem] rounded-tr-[2.25rem] bg-zinc-950 sm:h-[256px] sm:w-[196px] sm:rounded-[1.5rem] sm:rounded-tr-[2.5rem]"
                >
                  <img
                    src={img.heroHomeSemParar}
                    alt="Havaianas Personalizadas Terça da Serra — par sobre pedra com serra ao fundo"
                    class="bela-hero-collage-img bela-hero-float-media bela-hero-float-media--contain block h-full w-full max-w-none object-cover object-center"
                    loading="lazy"
                  />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bela-section bela-section-muted relative overflow-hidden py-20" aria-labelledby="vantagens-havaianas">
    <div
      class="pointer-events-none absolute left-1/2 top-0 h-40 w-[min(100%,42rem)] -translate-x-1/2 rounded-full bg-rose-600/[0.12] blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6">
      <h2
        id="vantagens-havaianas"
        class="text-2xl sm:text-3xl md:text-4xl font-bold text-center text-white mb-5 leading-tight max-w-3xl mx-auto"
      >
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-rose-200 via-rose-400 to-rose-300">
          Havaianas Personalizadas
        </span>
        <span class="text-zinc-100"> com estampa de alta durabilidade</span><br aria-hidden="true" /><span
          class="text-zinc-100"> com as cores do seu evento</span>
      </h2>
      <p class="text-zinc-400 text-center max-w-2xl mx-auto mb-14 text-base md:text-lg leading-relaxed">
        Casamento, formatura, 15 anos, aniversário ou brinde corporativo: suas{' '}
        <strong class="font-semibold text-zinc-200">Havaianas Personalizadas</strong> saem com solado Havaianas original, arte que
        conversa com o tema e prazos pensados no calendário da festa — do “sim” ao último convidado na pista.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        <article
          class="bela-diff-card group relative rounded-2xl border border-white/10 bg-gradient-to-b from-white/[0.07] to-white/[0.02] p-6 shadow-bela"
        >
          <div
            class="bela-diff-icon mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-rose-500/35 to-rose-600/10 ring-1 ring-rose-400/25"
          >
            <i class="fas fa-tags text-rose-200 text-xl" aria-hidden="true"></i>
          </div>
          <p class="mb-1 text-[11px] font-bold uppercase tracking-wider text-rose-400/80">Bolso agradece</p>
          <h3 class="mb-2 text-lg font-semibold text-white transition group-hover:text-rose-50">Preços que fazem sentido</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">
            Havaianas Personalizadas que cabem no seu orçamento - e <strong class="font-medium text-zinc-300">arte exclusiva</strong> que combina com seu evento.
          </p>
        </article>
        <article
          class="bela-diff-card group relative rounded-2xl border border-white/10 bg-gradient-to-b from-white/[0.07] to-white/[0.02] p-6 shadow-bela"
        >
          <div
            class="bela-diff-icon mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-rose-500/35 to-rose-600/10 ring-1 ring-rose-400/25"
          >
            <i class="fas fa-gem text-rose-200 text-xl" aria-hidden="true"></i>
          </div>
          <p class="mb-1 text-[11px] font-bold uppercase tracking-wider text-rose-400/80">Marca de verdade</p>
          <h3 class="mb-2 text-lg font-semibold text-white transition group-hover:text-rose-50">Havaianas originais</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">
            Produto e solado genuínos — aquela sensação que todo mundo reconhece. Lembrancinhas e{' '}
            <strong class="font-medium text-zinc-300">Havaianas Personalizadas</strong> com peso de marca, não de imitação.
          </p>
        </article>
        <article
          class="bela-diff-card group relative rounded-2xl border border-white/10 bg-gradient-to-b from-white/[0.07] to-white/[0.02] p-6 shadow-bela"
        >
          <div
            class="bela-diff-icon mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-rose-500/35 to-rose-600/10 ring-1 ring-rose-400/25"
          >
            <i class="fas fa-palette text-rose-200 text-xl" aria-hidden="true"></i>
          </div>
          <p class="mb-1 text-[11px] font-bold uppercase tracking-wider text-rose-400/80">Do desenho ao solado</p>
          <h3 class="mb-2 text-lg font-semibold text-white transition group-hover:text-rose-50">Estampa no solado</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">
            A estampa vai <strong class="font-medium text-zinc-300">direto no solado do chinelo</strong> — cor, monograma ou tema
            do evento com acabamento que aguenta a pista. Sua identidade, do dedão ao calcanhar.
          </p>
        </article>
        <article
          class="bela-diff-card group relative rounded-2xl border border-white/10 bg-gradient-to-b from-white/[0.07] to-white/[0.02] p-6 shadow-bela"
        >
          <div
            class="bela-diff-icon mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-rose-500/35 to-rose-600/10 ring-1 ring-rose-400/25"
          >
            <i class="fas fa-heart text-rose-200 text-xl" aria-hidden="true"></i>
          </div>
          <p class="mb-1 text-[11px] font-bold uppercase tracking-wider text-rose-400/80">Gente com gente</p>
          <h3 class="mb-2 text-lg font-semibold text-white transition group-hover:text-rose-50">Atendimento que acompanha</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">
            Prazo, quantidade, referência de cor — a gente ouve de verdade, do primeiro “oi” no Zap até o chinelo na mão do convidado.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="bela-section bela-section-deep py-20" aria-labelledby="produtos-por-evento">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <p class="mb-3 text-center text-xs font-semibold uppercase tracking-[0.18em] text-rose-400/90">
        Havaianas originais · estampa direto no solado
      </p>
      <h2
        id="produtos-por-evento"
        class="bela-hero-title-shine mx-auto mb-4 max-w-4xl text-center text-2xl font-bold leading-tight md:text-3xl lg:text-4xl"
      >
        Havaianas Personalizadas para cada festa — casamento, formatura, 15 anos e aniversários e eventos corporativos
      </h2>
      <p class="mx-auto mb-12 max-w-2xl text-center text-sm leading-relaxed text-zinc-400 md:text-base">
        Na Chinelos da Bela, suas <strong class="font-semibold text-zinc-300">Havaianas Personalizadas</strong> unem{' '}
        <strong class="font-semibold text-zinc-300">Havaianas originais</strong> e arte aplicada{' '}
        <strong class="font-semibold text-zinc-300">direto no solado do chinelo</strong>. Lembrancinhas e brindes com acabamento
        profissional, harmonizados com a identidade visual do seu evento — do altar à pista, da turma à marca.
      </p>
      <div class="mx-auto grid max-w-4xl gap-8 md:grid-cols-2 md:items-stretch">
        <a
          href="/produtos/casamento"
          class="bela-prod-home-card bela-prod-home-card--rose group flex h-full flex-col overflow-hidden rounded-xl border border-white/10 bg-zinc-900/35 shadow-lg no-underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-rose-400/55 focus-visible:ring-offset-2 focus-visible:ring-offset-[#111116]"
        >
          <div class="bela-prod-home-card__media aspect-[4/3] w-full shrink-0 bg-zinc-900/35">
            <img
              src={img.prodCasamento}
              alt="Noiva com Havaianas personalizadas nas mãos, vestido branco e véu, decoração de casamento ao fundo — Chinelos da Bela, São Paulo"
              class="bela-prod-home-card__img absolute inset-0 h-full w-full object-contain object-center"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="relative z-[1] flex flex-1 flex-col p-5">
            <h3 class="mb-1.5 text-lg font-bold text-white transition-colors duration-300 group-hover:text-rose-50">
              Havaianas Personalizadas para casamento
            </h3>
            <p class="mb-4 flex-1 text-sm leading-relaxed text-zinc-400 transition-colors duration-300 group-hover:text-zinc-300">
              Cores e arte alinhadas ao seu grande dia — conforto na pista e lembrança que combina com a identidade do evento.
            </p>
            <span
              class="bela-prod-home-card__cta inline-flex min-h-[44px] items-center gap-2 text-sm font-medium text-rose-300 group-hover:text-rose-200"
            >
              Ver linha casamento
              <i
                class="fas fa-arrow-right text-xs transition-transform duration-300 group-hover:translate-x-1"
                aria-hidden="true"
              ></i>
            </span>
          </div>
        </a>
        <a
          href="/produtos/formatura"
          class="bela-prod-home-card bela-prod-home-card--indigo group flex h-full flex-col overflow-hidden rounded-xl border border-white/10 bg-zinc-900/35 shadow-lg no-underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-400/55 focus-visible:ring-offset-2 focus-visible:ring-offset-[#111116]"
        >
          <div class="bela-prod-home-card__media aspect-[4/3] w-full shrink-0 bg-zinc-900/35">
            <img
              src={img.prodFormatura}
              alt="Formanda com beca segurando Havaianas personalizadas com estampa, colação de formatura — Chinelos da Bela, São Paulo"
              class="bela-prod-home-card__img absolute inset-0 h-full w-full object-contain object-center"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="relative z-[1] flex flex-1 flex-col p-5">
            <h3 class="mb-1.5 text-lg font-bold text-white transition-colors duration-300 group-hover:text-indigo-50">
              Havaianas Personalizadas para formatura
            </h3>
            <p class="mb-4 flex-1 text-sm leading-relaxed text-zinc-400 transition-colors duration-300 group-hover:text-zinc-300">
              Beca, confete e festa: lembrancinhas com as cores e o símbolo da turma — confortáveis da cerimônia à pista.
            </p>
            <span
              class="bela-prod-home-card__cta inline-flex min-h-[44px] items-center gap-2 text-sm font-medium text-indigo-300 group-hover:text-indigo-200"
            >
              Ver linha formatura
              <i
                class="fas fa-arrow-right text-xs transition-transform duration-300 group-hover:translate-x-1"
                aria-hidden="true"
              ></i>
            </span>
          </div>
        </a>
        <a
          href="/produtos/festa-15-anos"
          class="bela-prod-home-card bela-prod-home-card--fuchsia group flex h-full flex-col overflow-hidden rounded-xl border border-white/10 bg-zinc-900/35 shadow-lg no-underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-fuchsia-400/55 focus-visible:ring-offset-2 focus-visible:ring-offset-[#111116]"
        >
          <div class="bela-prod-home-card__media aspect-[4/3] w-full shrink-0 bg-zinc-900/35">
            <img
              src={img.prodFesta15}
              alt="Debutante com vestido rosa segurando Havaianas personalizadas rosa, mesa de lembrancinhas ao lado — Chinelos da Bela, São Paulo"
