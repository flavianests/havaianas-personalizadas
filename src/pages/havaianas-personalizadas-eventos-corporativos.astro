---
import ProdutoSeoPage from '../components/ProdutoSeoPage.astro';
import { siteConfig } from '../config';

const baseUrl = siteConfig.url.replace(/\/$/, '');
const img = siteConfig.images;
const pageUrl = `${baseUrl}/havaianas-personalizadas-eventos-corporativos/`;

const title = 'Havaianas Personalizadas para Empresas | Brindes Corporativos';
const metaDescription =
  'Havaianas personalizadas para eventos corporativos e empresas em todo o Brasil: brinde útil, marca no dia a dia, estampa na borracha e ótimo custo-benefício — Chinelos da Bela.';

const jsonLdExtra: Record<string, unknown>[] = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Início', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Produtos', item: `${baseUrl}/havaianas-personalizadas-produtos/` },
      {
        '@type': 'ListItem',
        position: 3,
        name: 'Havaianas personalizadas para eventos corporativos',
        item: pageUrl,
      },
    ],
  },
  {
    '@type': 'WebPage',
    '@id': `${pageUrl}#webpage`,
    url: pageUrl,
    name: `${title} | ${siteConfig.name}`,
    description: metaDescription,
    isPartOf: { '@id': `${baseUrl}/#website` },
    inLanguage: 'pt-BR',
  },
  {
    '@type': 'Service',
    name: 'Havaianas personalizadas para eventos corporativos',
    description: metaDescription,
    url: pageUrl,
    provider: { '@id': `${baseUrl}/#localbusiness` },
    serviceType: 'Brindes corporativos com personalização de chinelos Havaianas',
    areaServed: { '@type': 'Country', name: 'Brasil' },
  },
];

const breadcrumbs = [
  { href: '/', label: 'Início' },
  { href: '/havaianas-personalizadas-produtos', label: 'Produtos' },
  { href: '/havaianas-personalizadas-eventos-corporativos', label: 'Eventos corporativos' },
];
---

<ProdutoSeoPage
  title={title}
  description={metaDescription}
  h1="Havaianas Personalizadas para Eventos Corporativos"
  ogImage={`${baseUrl}${img.prodCorporativo}`}
  ogImageAlt="Havaianas personalizadas em stand corporativo e feira — Chinelos da Bela"
  heroImage={img.prodCorporativo}
  heroImageAlt="Stand corporativo com Havaianas personalizadas, participante apresentando chinelos da marca em feira ou convenção — Chinelos da Bela"
  heroImageObjectFit="contain"
  productCardsCurrentHref="/havaianas-personalizadas-eventos-corporativos"
  intro="As havaianas personalizadas para eventos corporativos são uma estratégia inteligente para empresas que desejam oferecer um brinde útil, marcante e com alto valor percebido. Diferente de brindes tradicionais que acabam esquecidos, os chinelos personalizados continuam sendo utilizados no dia a dia, mantendo sua marca presente por muito mais tempo."
  beforeSectionsParagraphs={[
    'Em eventos empresariais, cada detalhe contribui para a imagem da empresa. Por isso, escolher brindes que realmente geram impacto faz toda a diferença. As havaianas personalizadas combinam conforto, utilidade e visibilidade, sendo ideais para ações promocionais, feiras, convenções e confraternizações.',
  ]}
  whatsappContext="havaianas personalizadas para eventos corporativos"
  breadcrumbs={breadcrumbs}
  jsonLdExtra={jsonLdExtra}
  sections={[
    {
      heading: 'Chinelos Personalizados para Empresas: Marketing que Funciona',
      paragraphs: [
        'Os chinelos personalizados para eventos corporativos vão muito além de um simples brinde. Eles funcionam como uma ferramenta de marketing eficiente, ajudando a fortalecer a identidade da marca e criar conexão com o público.',
        'Ao incluir sua logo, cores e identidade visual nas havaianas personalizadas, sua empresa ganha visibilidade de forma natural. Como o produto é útil, ele continua sendo usado após o evento, ampliando o alcance da sua marca sem custo adicional.',
        'Esse tipo de brinde transmite uma imagem de cuidado e qualidade, o que impacta diretamente na percepção do cliente.',
      ],
    },
    {
      heading: 'Como usar Havaianas Personalizadas em Eventos Corporativos',
      bodyBlocks: [
        {
          type: 'p',
          text: 'As havaianas personalizadas podem ser utilizadas em diferentes tipos de eventos empresariais, adaptando-se facilmente a cada estratégia.',
        },
        { type: 'p', text: 'Algumas formas de uso incluem:' },
        {
          type: 'ul',
          items: [
            'Brinde em feiras e exposições',
            'Kits de boas-vindas para clientes',
            'Eventos internos e confraternizações',
            'Ações promocionais e campanhas de marketing',
            'Eventos ao ar livre e ativações de marca',
          ],
        },
        {
          type: 'p',
          text: 'Outra estratégia interessante é incluir os chinelos personalizados em kits exclusivos, junto com outros brindes, aumentando ainda mais o valor percebido.',
        },
      ],
    },
    {
      heading: 'Havaianas Personalizadas para Empresas: Vale o Investimento?',
      bodyBlocks: [
        {
          type: 'p',
          text: 'Sim, principalmente quando o objetivo é unir branding e utilidade.',
        },
        {
          type: 'p',
          text: 'O custo das havaianas personalizadas para eventos corporativos pode variar de acordo com:',
        },
        {
          type: 'ul',
          items: [
            'Quantidade solicitada',
            'Tipo de personalização',
            'Complexidade do design',
            'Prazo de produção',
          ],
        },
        {
          type: 'p',
          text: 'Mesmo assim, o investimento costuma ter excelente retorno, já que o produto continua sendo utilizado por muito tempo, mantendo sua marca em evidência.',
        },
        {
          type: 'p',
          text: 'Aqui na Chinelos da Bela, você pode personalizar as havaianas conforme sua identidade visual sem alteração no valor, garantindo liberdade criativa e ótimo custo-benefício.',
        },
      ],
    },
    {
      heading: 'Diferenciais das Nossas Havaianas Personalizadas',
      bodyBlocks: [
        {
          type: 'p',
          text: 'Para eventos corporativos, a qualidade do brinde é fundamental. Um produto bem feito reforça a imagem da empresa e transmite profissionalismo.',
        },
        { type: 'p', text: 'Confira nossos diferenciais:' },
        {
          type: 'ul',
          items: [
            'Estampa direto na borracha (não desbota)',
            'Alta durabilidade',
            'Conforto original Havaianas',
            'Personalização com identidade da sua marca',
            'Produção profissional',
            'Entrega rápida e segura',
          ],
        },
        {
          type: 'p',
          text: 'Nosso processo garante que cada par seja produzido com alto padrão, representando sua marca da melhor forma possível.',
        },
      ],
    },
    {
      heading: 'Por que Havaianas Personalizadas são um dos melhores brindes corporativos?',
      bodyBlocks: [
        {
          type: 'p',
          text: 'As havaianas personalizadas se destacam no mercado porque unem diversos benefícios em um único produto:',
        },
        {
          type: 'ul',
          items: [
            'Alta utilidade no dia a dia',
            'Grande aceitação do público',
            'Excelente exposição da marca',
            'Durabilidade',
            'Diferencial competitivo em eventos',
          ],
        },
        {
          type: 'p',
          text: 'Diferente de brindes comuns, os chinelos personalizados não são descartados. Isso faz com que sua marca permaneça presente na rotina do cliente, aumentando o reconhecimento e a lembrança.',
        },
      ],
    },
    {
      heading: 'Atendimento para Empresas em Todo o Brasil',
      paragraphs: [
        'Atendemos empresas em São Paulo e em todo o Brasil, oferecendo havaianas personalizadas para eventos corporativos com agilidade e qualidade.',
        'Seja para pequenas ações ou grandes eventos, temos estrutura para atender diferentes demandas, sempre respeitando prazos e garantindo um produto final de alto nível.',
      ],
    },
    {
      heading: 'Solicite um orçamento para sua empresa',
      paragraphs: [
        'Se você está buscando havaianas personalizadas para eventos corporativos com qualidade, durabilidade e excelente custo-benefício, entre em contato com a gente.',
        'Produzimos chinelos personalizados com a identidade da sua marca, ideais para fortalecer sua presença em eventos e ações promocionais.',
        'Solicite agora seu orçamento e leve sua marca para o dia a dia dos seus clientes com um brinde útil e estratégico!',
      ],
      showRoseOrcamentoButton: true,
    },
  ]}
/>
