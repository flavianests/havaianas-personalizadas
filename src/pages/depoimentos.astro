---
import BaseLayout from '../layouts/BaseLayout.astro';
import NossosClientesCarousel from '../components/NossosClientesCarousel.astro';
---

<BaseLayout
  title="Depoimentos"
  description="Depoimentos de noivas e clientes da Chinelos da Bela — Havaianas Personalizadas e lembrancinhas de evento."
>
  <section class="bela-section relative overflow-hidden bg-[#111116] py-16 text-white md:py-24" aria-labelledby="depoimentos-titulo">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <h1 id="depoimentos-titulo" class="text-center text-3xl font-bold text-white md:text-4xl">
        O que falam de nós
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-center text-sm leading-relaxed text-zinc-400 md:text-base">
        Depoimentos reais de quem confia na Chinelos da Bela para Havaianas Personalizadas e chinelos para eventos.
      </p>
      <div class="mt-14">
        <NossosClientesCarousel />
      </div>
    </div>
  </section>
</BaseLayout>
