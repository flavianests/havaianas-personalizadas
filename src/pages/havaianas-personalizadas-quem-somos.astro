---
import { siteConfig } from '../config';

const targetPath = '/quem-somos';
const base = siteConfig.url.replace(/\/$/, '');
const canonical = `${base}${targetPath}`;
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Redirecionando…</title>
    <link rel="canonical" href={canonical} />
    <meta http-equiv="refresh" content={`0;url=${targetPath}`} />
  </head>
  <body>
    <p><a href={targetPath}>Continuar para Quem somos</a></p>
    <script is:inline>
      location.replace('/quem-somos');
    </script>
  </body>
</html>
