---
import ProdutoSeoPage from '../../components/ProdutoSeoPage.astro';
import { siteConfig } from '../../config';

const baseUrl = siteConfig.url.replace(/\/$/, '');
const img = siteConfig.images;
const pageUrl = `${baseUrl}/produtos/casamento/`;

const title = 'Havaianas personalizadas para casamento em São Paulo';
const metaDescription =
  'Havaianas personalizadas para casamento: lembrancinhas com sola original e estampa no solado. Chinelos da Bela — conforto para a pista e memória para os convidados. Peça orçamento.';

const jsonLdExtra: Record<string, unknown>[] = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Início', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Produtos', item: `${baseUrl}/servicos/` },
      {
        '@type': 'ListItem',
        position: 3,
        name: 'Havaianas personalizadas para casamento',
        item: pageUrl,
      },
    ],
  },
  {
    '@type': 'WebPage',
    '@id': `${pageUrl}#webpage`,
    url: pageUrl,
    name: `${title} | ${siteConfig.name}`,
    description: metaDescription,
    isPartOf: { '@id': `${baseUrl}/#website` },
    inLanguage: 'pt-BR',
  },
  {
    '@type': 'Service',
    name: 'Havaianas personalizadas para casamento',
    description: metaDescription,
    url: pageUrl,
    provider: { '@id': `${baseUrl}/#localbusiness` },
    serviceType: 'Personalização de chinelos Havaianas para casamentos e recepções',
    areaServed: { '@type': 'AdministrativeArea', name: 'São Paulo' },
  },
];

const breadcrumbs = [
  { href: '/', label: 'Início' },
  { href: '/servicos', label: 'Produtos' },
  { href: '/produtos/casamento', label: 'Casamento' },
];

const related = [
  { href: '/produtos/festa-15-anos', label: 'Festa de 15 anos' },
  { href: '/produtos/formatura', label: 'Formatura' },
  { href: '/produtos/eventos-corporativos', label: 'Eventos corporativos' },
];
---

<ProdutoSeoPage
  title={title}
  description={metaDescription}
  h1="Havaianas personalizadas para casamento"
  ogImage={`${baseUrl}${img.destaqueHavaianas}`}
  ogImageAlt="Havaianas personalizadas para casamento — estampa no solado, Chinelos da Bela"
  heroImage={img.prodCasamento}
  heroImageAlt="Noiva com Havaianas personalizadas nas mãos, vestido branco e véu, decoração de casamento ao fundo — Chinelos da Bela, São Paulo"
  heroImageObjectFit="contain"
  intro="Surpreenda os convidados com lembrancinhas úteis e cheias de personalidade. Na Chinelos da Bela, produzimos havaianas personalizadas para casamento com sola Havaianas original e arte aplicada direto no solado — ideais para a festa, a pista e a praia no dia seguinte."
  whatsappContext="havaianas personalizadas para casamento"
  breadcrumbs={breadcrumbs}
  jsonLdExtra={jsonLdExtra}
  related={related}
  sections={[
    {
      heading: 'Por que oferecer havaianas no casamento?',
      paragraphs: [
        'Após horas de cerimônia e salão, muitos convidados agradecem poder trocar o salto ou o sapato social por algo confortável sem sair do clima da festa. As havaianas personalizadas viram lembrança que as pessoas realmente usam — e associam ao seu grande dia.',
        'Você pode alinhar cores, monogramas, data e elementos da identidade visual do casamento à estampa, mantendo harmonia com convites, decoração e papelaria.',
      ],
    },
    {
      heading: 'Qualidade e personalização com a Chinelos da Bela',
      paragraphs: [
        'Trabalhamos com chinelos Havaianas originais e personalização profissional no solado, com atenção ao acabamento para que o resultado fique nítido e durável.',
        'Atendemos noivos e assessorias e enviamos para outras localidades conforme combinação — fale pelo WhatsApp com data aproximada do evento, quantidade e referências visuais (cores, logo ou monograma) para receber orientação e orçamento.',
      ],
    },
    {
      heading: 'Boas práticas para planejar as lembrancinhas',
      paragraphs: [
        'Reserve um tempo na timeline do casamento para definir tamanhos (masculino/feminino/infantil) e quantidades com folga para convidados extras.',
        'Se quiser usar as havaianas na própria recepção (cesta na entrada ou distribuição na pista), combinamos prazos de produção para tudo chegar com tranquilidade antes do evento.',
      ],
    },
  ]}
/>
