---
import ProdutoSeoPage from '../../components/ProdutoSeoPage.astro';
import { siteConfig } from '../../config';

const baseUrl = siteConfig.url.replace(/\/$/, '');
const img = siteConfig.images;
const pageUrl = `${baseUrl}/produtos/eventos-corporativos/`;

const title = 'Havaianas personalizadas para eventos corporativos em São Paulo';
const metaDescription =
  'Havaianas personalizadas para eventos corporativos: brindes com logo, convenções e confraternizações. Chinelos da Bela — Havaianas originais, estampa no solado. Orçamento para empresas pelo WhatsApp.';

const jsonLdExtra: Record<string, unknown>[] = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Início', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Produtos', item: `${baseUrl}/servicos/` },
      {
        '@type': 'ListItem',
        position: 3,
        name: 'Havaianas personalizadas para eventos corporativos',
        item: pageUrl,
      },
    ],
  },
  {
    '@type': 'WebPage',
    '@id': `${pageUrl}#webpage`,
    url: pageUrl,
    name: `${title} | ${siteConfig.name}`,
    description: metaDescription,
    isPartOf: { '@id': `${baseUrl}/#website` },
    inLanguage: 'pt-BR',
  },
  {
    '@type': 'Service',
    name: 'Havaianas personalizadas para eventos corporativos',
    description: metaDescription,
    url: pageUrl,
    provider: { '@id': `${baseUrl}/#localbusiness` },
    serviceType: 'Brindes corporativos com personalização de chinelos Havaianas',
    areaServed: { '@type': 'AdministrativeArea', name: 'São Paulo' },
  },
];

const breadcrumbs = [
  { href: '/', label: 'Início' },
  { href: '/servicos', label: 'Produtos' },
  { href: '/produtos/eventos-corporativos', label: 'Eventos corporativos' },
];

const related = [
  { href: '/produtos/casamento', label: 'Casamento' },
  { href: '/produtos/festa-15-anos', label: 'Festa de 15 anos' },
  { href: '/produtos/formatura', label: 'Formatura' },
];
---

<ProdutoSeoPage
  title={title}
  description={metaDescription}
  h1="Havaianas personalizadas para eventos corporativos"
  ogImage={`${baseUrl}${img.prodCorporativo}`}
  ogImageAlt="Havaianas personalizadas em stand corporativo e feira — Chinelos da Bela, São Paulo"
  heroImage={img.prodCorporativo}
  heroImageAlt="Stand corporativo com Havaianas personalizadas, participante apresentando chinelos da marca em feira ou convenção — Chinelos da Bela, São Paulo"
  heroImageObjectFit="contain"
  intro="Brindes corporativos precisam ser memoráveis e alinhados à marca. As havaianas personalizadas para eventos corporativos associam conforto e visibilidade da empresa em convenções, feiras, lançamentos e confraternizações. Na Chinelos da Bela, aplicamos sua identidade visual com qualidade na sola Havaianas original."
  whatsappContext="havaianas personalizadas para eventos corporativos"
  breadcrumbs={breadcrumbs}
  jsonLdExtra={jsonLdExtra}
  related={related}
  sections={[
    {
      heading: 'Marca presente no dia a dia',
      paragraphs: [
        'Diferente de itens que ficam na gaveta, um chinelo personalizado tende a ser usado em casa, na praia ou no lazer — mantendo logo e mensagem expostos por mais tempo.',
        'A estampa no solado permite área criativa para slogan, hashtag de campanha ou elementos gráficos da identidade visual.',
      ],
    },
    {
      heading: 'Eventos que pedem conforto',
      paragraphs: [
        'Workshops em resort, festas de fim de ano, ações de verão e ativações ao ar livre combinam com entrega de havaianas como kit de boas-vindas ou prêmio.',
        'Atendemos demandas com volumes variados; informe data do evento, local de entrega e manual da marca (cores Pantone, área de respiro do logo) para alinharmos a prova digital.',
      ],
    },
    {
      heading: 'Processo e contato comercial',
      paragraphs: [
        'Envie briefing com quantidade por numeração, prazo e referência de arte. Retornamos com orientações e orçamento.',
        'Também despachamos para outras regiões conforme combinado — fale pelo WhatsApp com prazo e local de entrega.',
      ],
    },
  ]}
/>
