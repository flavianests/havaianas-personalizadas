---
import ProdutoSeoPage from '../../components/ProdutoSeoPage.astro';
import { siteConfig } from '../../config';

const baseUrl = siteConfig.url.replace(/\/$/, '');
const img = siteConfig.images;
const pageUrl = `${baseUrl}/produtos/formatura/`;

const title = 'Havaianas personalizadas para formatura em São Paulo';
const metaDescription =
  'Havaianas personalizadas para formatura: turma, colação e festa com sola Havaianas e estampa no solado. Chinelos da Bela — brindes memoráveis. Solicite orçamento pelo WhatsApp.';

const jsonLdExtra: Record<string, unknown>[] = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Início', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Produtos', item: `${baseUrl}/servicos/` },
      {
        '@type': 'ListItem',
        position: 3,
        name: 'Havaianas personalizadas para formatura',
        item: pageUrl,
      },
    ],
  },
  {
    '@type': 'WebPage',
    '@id': `${pageUrl}#webpage`,
    url: pageUrl,
    name: `${title} | ${siteConfig.name}`,
    description: metaDescription,
    isPartOf: { '@id': `${baseUrl}/#website` },
    inLanguage: 'pt-BR',
  },
  {
    '@type': 'Service',
    name: 'Havaianas personalizadas para formatura',
    description: metaDescription,
    url: pageUrl,
    provider: { '@id': `${baseUrl}/#localbusiness` },
    serviceType: 'Personalização de chinelos Havaianas para formaturas e eventos acadêmicos',
    areaServed: { '@type': 'AdministrativeArea', name: 'São Paulo' },
  },
];

const breadcrumbs = [
  { href: '/', label: 'Início' },
  { href: '/servicos', label: 'Produtos' },
  { href: '/produtos/formatura', label: 'Formatura' },
];

const related = [
  { href: '/produtos/casamento', label: 'Casamento' },
  { href: '/produtos/festa-15-anos', label: 'Festa de 15 anos' },
  { href: '/produtos/eventos-corporativos', label: 'Eventos corporativos' },
];
---

<ProdutoSeoPage
  title={title}
  description={metaDescription}
  h1="Havaianas personalizadas para formatura"
  ogImage={`${baseUrl}${img.destaqueHavaianas}`}
  ogImageAlt="Havaianas personalizadas para formatura — formando com estampa no solado, Chinelos da Bela"
  heroImage={img.prodFormatura}
  heroImageAlt="Formanda com beca segurando Havaianas personalizadas com estampa, colação de formatura — Chinelos da Bela, São Paulo"
  heroImageObjectFit="contain"
  intro="Formaturas reúnem família, amigos e muita foto. As havaianas personalizadas para formatura unem o simbolismo do curso com um brinde que todos usam depois da cerimônia. A Chinelos da Bela personaliza Havaianas originais com estampa profissional no solado — para turmas, comissões e convidados."
  whatsappContext="havaianas personalizadas para formatura"
  breadcrumbs={breadcrumbs}
  jsonLdExtra={jsonLdExtra}
  related={related}
  sections={[
    {
      heading: 'Identidade da turma na sola',
      paragraphs: [
        'Logo do curso, ano de conclusão, símbolo da instituição ou frase da turma podem compor a arte, reforçando pertencimento e memória coletiva.',
        'É uma alternativa criativa a canecas e camisetas apenas — complementa o kit de formatura com item leve e prático.',
      ],
    },
    {
      heading: 'Do ensaio à festa: versatilidade',
      paragraphs: [
        'Muitas turmas usam os chinelos em ensaios fotográficos, churrascos pré-formatura e na própria festa, quando o salto já cansou.',
        'Combinamos prazos conforme data da colação ou evento; entre em contato com antecedência para garantir produção e revisão da arte.',
      ],
    },
    {
      heading: 'Orçamento para turma ou comissão',
      paragraphs: [
        'Informe quantidade total, faixas de tamanho e se há necessidade de embalagem individual ou kits.',
        'Se já existir arquivo vetorial ou manual da identidade visual da turma, o processo de aprovação da arte costuma ser mais rápido.',
      ],
    },
  ]}
/>
