---
import ProdutoSeoPage from '../../components/ProdutoSeoPage.astro';
import { siteConfig } from '../../config';

const baseUrl = siteConfig.url.replace(/\/$/, '');
const img = siteConfig.images;
const pageUrl = `${baseUrl}/produtos/festa-15-anos/`;

const title = 'Havaianas personalizadas para festa de 15 anos em São Paulo';
const metaDescription =
  'Havaianas personalizadas para festa de 15 anos: debutante e convidados com conforto e estilo. Chinelos da Bela — Havaianas originais, estampa no solado. Peça orçamento pelo WhatsApp.';

const jsonLdExtra: Record<string, unknown>[] = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Início', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Produtos', item: `${baseUrl}/servicos/` },
      {
        '@type': 'ListItem',
        position: 3,
        name: 'Havaianas personalizadas para festa de 15 anos',
        item: pageUrl,
      },
    ],
  },
  {
    '@type': 'WebPage',
    '@id': `${pageUrl}#webpage`,
    url: pageUrl,
    name: `${title} | ${siteConfig.name}`,
    description: metaDescription,
    isPartOf: { '@id': `${baseUrl}/#website` },
    inLanguage: 'pt-BR',
  },
  {
    '@type': 'Service',
    name: 'Havaianas personalizadas para festa de 15 anos',
    description: metaDescription,
    url: pageUrl,
    provider: { '@id': `${baseUrl}/#localbusiness` },
    serviceType: 'Personalização de chinelos Havaianas para debutantes e festas de quinze anos',
    areaServed: { '@type': 'AdministrativeArea', name: 'São Paulo' },
  },
];

const breadcrumbs = [
  { href: '/', label: 'Início' },
  { href: '/servicos', label: 'Produtos' },
  { href: '/produtos/festa-15-anos', label: 'Festa de 15 anos' },
];

const related = [
  { href: '/produtos/casamento', label: 'Casamento' },
  { href: '/produtos/formatura', label: 'Formatura' },
  { href: '/produtos/eventos-corporativos', label: 'Eventos corporativos' },
];
---

<ProdutoSeoPage
  heroImageScale="large"
  title={title}
  description={metaDescription}
  h1="Havaianas personalizadas para festa de 15 anos"
  ogImage={`${baseUrl}${img.prodFesta15}`}
  ogImageAlt="Debutante com vestido rosa e Havaianas personalizadas — festa de 15 anos, Chinelos da Bela, São Paulo"
  heroImage={img.prodFesta15}
  heroImageAlt="Debutante com vestido rosa segurando Havaianas personalizadas rosa, mesa de lembrancinhas ao lado — Chinelos da Bela, São Paulo"
  heroImageObjectFit="contain"
  intro="A festa de quinze anos merece detalhes que combinem glamour, diversão e conforto. As havaianas personalizadas para festa de 15 anos são lembrancinhas modernas para convidados e um toque especial na mesa de presentes ou na pista. Na Chinelos da Bela, você conta com Havaianas originais e personalização com estampa no solado."
  whatsappContext="havaianas personalizadas para festa de 15 anos"
  breadcrumbs={breadcrumbs}
  jsonLdExtra={jsonLdExtra}
  related={related}
  sections={[
    {
      heading: 'Lembrancinha que combina com a debutante',
      paragraphs: [
        'Tons do vestido, coroa, tema da festa ou monograma podem inspirar a arte do solado, criando identidade visual única para o evento.',
        'Além da debutante, os convidados levam para casa um item útil — diferente de apenas doces ou objetos decorativos que ficam guardados.',
      ],
    },
    {
      heading: 'Conforto do início da festa ao último passo de dança',
      paragraphs: [
        'Salões e pistas pedem calçados que aguentem horas de celebração. Entregar havaianas personalizadas na entrada ou em um momento da festa melhora a experiência de quem está de salto ou sapato fechado.',
        'Produzimos com processos pensados para definição nítida da arte e acabamento alinhado ao padrão Chinelos da Bela.',
      ],
    },
    {
      heading: 'Como solicitar orçamento',
      paragraphs: [
        'Envie pelo WhatsApp a data prevista, cidade de entrega, quantidade aproximada e referências (fotos de inspiração, paleta ou arquivo de logo).',
        'Indique se precisa de numerações variadas (infantil, feminino, masculino) para dimensionarmos o pedido corretamente.',
      ],
    },
  ]}
/>
