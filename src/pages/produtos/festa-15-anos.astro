---
import ProdutoSeoPage from '../../components/ProdutoSeoPage.astro';
import { siteConfig } from '../../config';

const baseUrl = siteConfig.url.replace(/\/$/, '');
const img = siteConfig.images;
const pageUrl = `${baseUrl}/produtos/festa-15-anos/`;

/** SEO: título 60 caracteres; meta 159 caracteres (recom. ~150–160 Google) */
const title = 'Havaianas personalizadas festa 15 anos | Chinelos da Bela';
const metaDescription =
  'Havaianas para festa de 15 anos: debutante e convidados, sola original e estampa no solado. Chinelos da Bela — orçamento, prazos e entrega pelo WhatsApp.';

const jsonLdExtra: Record<string, unknown>[] = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Início', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Produtos', item: `${baseUrl}/servicos/` },
      {
        '@type': 'ListItem',
        position: 3,
        name: 'Havaianas personalizadas para festa de 15 anos',
        item: pageUrl,
      },
    ],
  },
  {
    '@type': 'WebPage',
    '@id': `${pageUrl}#webpage`,
    url: pageUrl,
    name: `${title}`,
    description: metaDescription,
    isPartOf: { '@id': `${baseUrl}/#website` },
    inLanguage: 'pt-BR',
  },
  {
    '@type': 'Service',
    name: 'Havaianas personalizadas para festa de 15 anos',
    description: metaDescription,
    url: pageUrl,
    provider: { '@id': `${baseUrl}/#localbusiness` },
    serviceType: 'Personalização de chinelos Havaianas para debutantes e festas de quinze anos',
    areaServed: { '@type': 'Country', name: 'Brasil' },
  },
];

const breadcrumbs = [
  { href: '/', label: 'Início' },
  { href: '/servicos', label: 'Produtos' },
  { href: '/produtos/festa-15-anos', label: 'Festa de 15 anos' },
];
---

<ProdutoSeoPage
  heroImageScale="large"
  title={title}
  description={metaDescription}
  h1="Havaianas personalizadas para festa de 15 anos"
  ogImage={`${baseUrl}${img.prodFesta15}`}
  ogImageAlt="Debutante com vestido rosa e Havaianas personalizadas — festa de 15 anos, Chinelos da Bela"
  heroImage={img.prodFesta15}
  heroImageAlt="Debutante com vestido rosa segurando Havaianas personalizadas rosa, mesa de lembrancinhas ao lado — Chinelos da Bela"
  heroImageObjectFit="cover"
  productCardsCurrentHref="/produtos/festa-15-anos"
  ctaOrcamentoIntro="Organizando o debut? Envie pelo WhatsApp data da festa, local, número aproximado de convidados e referências de tema ou cores. A Chinelos da Bela orienta quantidades por numeração, prazos de produção e personalização em havaianas para festa de 15 anos com acabamento profissional no solado."
  intro="Glamour e conforto para a debutante e os convidados: havaianas personalizadas para festa de 15 anos com sola Havaianas original e estampa no solado — lembrancinhas para mesa de presentes ou pista. Atendimento Chinelos da Bela para quem busca “lembrancinha 15 anos” ou chinelos temáticos alinhados à identidade visual da festa."
  whatsappContext="havaianas personalizadas para festa de 15 anos"
  breadcrumbs={breadcrumbs}
  jsonLdExtra={jsonLdExtra}
  sections={[
    {
      heading: 'Lembrancinhas de 15 anos alinhadas à identidade da festa',
      paragraphs: [
        'Cores do vestido, coroa, tema ou monograma podem inspirar a arte do solado para uma identidade visual única.',
        'Convidados levam item útil — além de doces e lembranças que ficam só na gaveta.',
        'Lembrancinhas de debutante ganham credibilidade com sola original e estampa legível no solado — foco da Chinelos da Bela em cada lote.',
      ],
    },
    {
      heading: 'Conforto da abertura à última música',
      paragraphs: [
        'Salão e pista pedem calçados que aguentem horas. Distribuir havaianas na entrada ou em um momento da festa melhora a experiência de quem está de salto.',
        'Produção com arte nítida e acabamento Chinelos da Bela.',
        'Pais e debutante podem combinar kits especiais (padrinhos, mesa) com o mesmo layout de arte em volumes diferentes.',
      ],
    },
    {
      heading: 'O que preparar antes de chamar no WhatsApp',
      paragraphs: [
        'Tenha em mãos data prevista, cidade, quantidade aproximada e referências (paleta, logo ou fotos de inspiração).',
        'Indique numerações (infantil, feminino, masculino) para dimensionar o pedido e evitar falta de tamanhos na hora da entrega.',
        'O botão verde abaixo leva direto ao WhatsApp para solicitar orçamento com a mesma mensagem contextualizada desta linha.',
      ],
    },
  ]}
/>
