---
/**
 * Trilha visual + semântica para SEO (complementa JSON-LD BreadcrumbList)
 */
export interface BreadcrumbItem {
  href: string;
  label: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav class="mx-auto max-w-6xl px-4 pt-4 sm:px-6 sm:pt-6" aria-label="Trilha de navegação">
  <ol class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-zinc-500">
    {
      items.map((item, i) => (
        <li class="flex items-center gap-2">
          {i > 0 && (
            <span class="text-zinc-600" aria-hidden="true">
              /
            </span>
          )}
          {i < items.length - 1 ? (
            <a href={item.href} class="text-zinc-400 hover:text-rose-300 transition-colors min-h-[44px] inline-flex items-center">
              {item.label}
            </a>
          ) : (
            <span class="text-zinc-300 font-medium" aria-current="page">
              {item.label}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
