---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBreadcrumbs from './PageBreadcrumbs.astro';
import type { BreadcrumbItem } from './PageBreadcrumbs.astro';
import { siteConfig, whatsappHref } from '../config';

interface Section {
  heading: string;
  paragraphs: string[];
}

interface RelatedLink {
  href: string;
  label: string;
}

interface Props {
  title: string;
  description: string;
  h1: string;
  ogImage: string;
  ogImageAlt: string;
  /** Mesma foto do card desse produto em /servicos e home */
  heroImage: string;
  heroImageAlt: string;
  intro: string;
  sections: Section[];
  whatsappContext: string;
  breadcrumbs: BreadcrumbItem[];
  jsonLdExtra: Record<string, unknown>[];
  /** Links “Outras linhas” no rodapé do conteúdo */
  related?: RelatedLink[];
  /** `large` = área da foto maior (ex.: festa de 15 anos) */
  heroImageScale?: 'default' | 'large';
  /** Retratos: ancora no topo para não cortar rosto no `object-cover` */
  heroImageObjectPosition?: 'center' | 'top';
  /** `contain` = foto inteira visível no quadro (sem cortar; pode haver faixas laterais) */
  heroImageObjectFit?: 'cover' | 'contain';
}

const {
  title,
  description,
  h1,
  ogImage,
  ogImageAlt,
  heroImage,
  heroImageAlt,
  intro,
  sections,
  whatsappContext,
  breadcrumbs,
  jsonLdExtra,
  related = [],
  heroImageScale = 'default',
  heroImageObjectPosition = 'center',
  heroImageObjectFit = 'cover',
} = Astro.props;

const wa = whatsappHref(
  siteConfig.whatsappPhone,
  `Olá! Tenho interesse em ${whatsappContext}.`
);

const imageColClass =
  heroImageScale === 'large'
    ? 'mx-auto w-full max-w-xl sm:max-w-2xl lg:mx-0 lg:max-w-none'
    : 'w-full';
---

<BaseLayout {title} {description} image={ogImage} {ogImageAlt} jsonLdExtra={jsonLdExtra}>
  <PageBreadcrumbs items={breadcrumbs} />
  <article class="bela-section bela-section-muted py-10 md:py-14 lg:py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <!-- Hero alinhado a /servicos: foto à esquerda no desktop; no mobile, texto primeiro -->
      <section
        class="mb-12 scroll-mt-28 md:mb-14"
        aria-labelledby="produto-titulo-principal"
      >
        <div class="grid items-center gap-10 lg:grid-cols-2">
          <div class:list={['order-2 lg:order-1', imageColClass]}>
            <div class="bela-surface-card group overflow-hidden !rounded-2xl !p-0 shadow-bela">
              <div class="relative aspect-[4/3] w-full overflow-hidden bg-zinc-950">
                <img
                  src={heroImage}
                  alt={heroImageAlt}
                  class:list={[
                    'absolute inset-0 h-full w-full transition-transform duration-500 group-hover:scale-[1.03]',
                    heroImageObjectFit === 'contain'
                      ? 'object-contain object-center'
                      : [
                          'object-cover',
                          heroImageObjectPosition === 'top' ? 'object-top' : 'object-center',
                        ],
                  ]}
                  width="1200"
                  height="900"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                />
              </div>
            </div>
          </div>
          <div class="order-1 text-center lg:order-2 lg:text-left">
            <p class="mb-3 text-xs font-semibold uppercase tracking-[0.22em] text-rose-300/85">
              Chinelos da Bela
            </p>
            <h1
              id="produto-titulo-principal"
              class="text-3xl font-bold leading-tight text-white sm:text-4xl lg:text-[2.35rem] xl:text-5xl"
            >
              {h1}
            </h1>
            <span
              class="mx-auto mt-5 block h-1 w-14 max-w-full rounded-full bg-gradient-to-r from-rose-500 via-rose-400 to-indigo-400 lg:mx-0"
              aria-hidden="true"
            ></span>
            <p class="mt-6 text-base leading-relaxed text-zinc-400 sm:text-lg">
              {intro}
            </p>
            <p class="mt-6">
              <a
                href={wa}
                target="_blank"
                rel="noopener noreferrer"
                class="bela-cta-pulse-whatsapp inline-flex min-h-[48px] items-center gap-2 rounded-full bg-[#25D366] px-8 font-semibold text-white transition-colors hover:bg-[#20bd5a]"
                aria-label={`Solicitar orçamento de ${whatsappContext} pelo WhatsApp`}
              >
                <i class="fab fa-whatsapp text-xl" aria-hidden="true"></i>
                Solicitar orçamento
              </a>
            </p>
          </div>
        </div>
      </section>

      <div class="prose prose-invert prose-zinc max-w-none space-y-12">
        {
          sections.map((s, idx) => (
            <section class="border-t border-white/[0.08] pt-10 first:border-0 first:pt-0" aria-labelledby={`sec-${idx}`}>
              <h2 id={`sec-${idx}`} class="mb-4 text-2xl font-bold text-white md:text-3xl">
                {s.heading}
              </h2>
              <div class="space-y-4 text-zinc-400 leading-relaxed">
                {s.paragraphs.map((p) => (
                  <p>{p}</p>
                ))}
              </div>
            </section>
          ))
        }
      </div>

      {
        related.length > 0 && (
          <nav
            class="mt-14 border-t border-white/[0.08] pt-10"
            aria-label="Outras linhas de produtos"
          >
            <h2 class="mb-4 text-xl font-bold text-white md:text-2xl">Outras linhas</h2>
            <ul class="flex flex-wrap gap-3">
              {related.map((r) => (
                <li>
                  <a
                    href={r.href}
                    class="inline-flex min-h-[44px] items-center rounded-full border border-white/15 bg-white/[0.04] px-4 py-2 text-sm font-medium text-rose-200/90 transition-colors hover:border-rose-400/40 hover:bg-white/[0.07] hover:text-rose-100"
                  >
                    {r.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }
    </div>
  </article>
</BaseLayout>
