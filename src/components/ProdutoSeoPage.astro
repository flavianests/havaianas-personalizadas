---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBreadcrumbs from './PageBreadcrumbs.astro';
import type { BreadcrumbItem } from './PageBreadcrumbs.astro';
import ProdutoCardsGrid from './ProdutoCardsGrid.astro';
import { siteConfig, whatsappHref } from '../config';

type SectionBodyItem =
  | { type: 'p'; text: string }
  | { type: 'ul'; items: string[] };

interface Section {
  heading: string;
  /** Corpo rico em ordem (parágrafos e listas); se definido, ignora paragraphs/bulletList/paragraphsAfterList */
  bodyBlocks?: SectionBodyItem[];
  paragraphs?: string[];
  /** Itens de lista após os parágrafos iniciais (ex.: ideias de design) */
  bulletList?: string[];
  /** Parágrafos após a lista, ainda dentro da mesma seção */
  paragraphsAfterList?: string[];
  /** Botão rosa “Solicitar orçamento” (WhatsApp) ao final desta seção */
  showRoseOrcamentoButton?: boolean;
}

interface RelatedLink {
  href: string;
  label: string;
}

interface Props {
  title: string;
  description: string;
  h1: string;
  ogImage: string;
  ogImageAlt: string;
  /** Mesma foto do card desse produto em /servicos e home */
  heroImage: string;
  heroImageAlt: string;
  intro: string | string[];
  sections: Section[];
  whatsappContext: string;
  breadcrumbs: BreadcrumbItem[];
  jsonLdExtra: Record<string, unknown>[];
  /** Links “Outras linhas” no rodapé do conteúdo */
  related?: RelatedLink[];
  /** `large` = área da foto maior (ex.: festa de 15 anos) */
  heroImageScale?: 'default' | 'large';
  /** Retratos: ancora no topo para não cortar rosto no `object-cover` */
  heroImageObjectPosition?: 'center' | 'top';
  /** `contain` = foto inteira visível no quadro (sem cortar; pode haver faixas laterais) */
  heroImageObjectFit?: 'cover' | 'contain';
  /** Grelha de produtos (home/servicos): destaca a linha atual */
  productCardsCurrentHref?: string;
  /** Parágrafos antes da primeira seção (H2) do artigo (opcional) */
  beforeSectionsParagraphs?: string[];
  /** Legado: mesmo efeito que beforeSectionsParagraphs (evita erro se ainda for passado) */
  footerParagraphs?: string[];
}

const {
  title,
  description,
  h1,
  ogImage,
  ogImageAlt,
  heroImage,
  heroImageAlt,
  intro,
  sections,
  whatsappContext,
  breadcrumbs,
  jsonLdExtra,
  related = [],
  heroImageScale = 'default',
  heroImageObjectPosition = 'center',
  heroImageObjectFit = 'cover',
  productCardsCurrentHref,
  beforeSectionsParagraphs: beforeSectionsParagraphsProp,
  footerParagraphs: footerParagraphsProp,
} = Astro.props;

const beforeSectionsParagraphs =
  beforeSectionsParagraphsProp ?? footerParagraphsProp ?? [];
/** Alias para compatibilidade com builds/cache que ainda referenciam o nome antigo */
const footerParagraphs = beforeSectionsParagraphs;

const wa = whatsappHref(
  siteConfig.whatsappPhone,
  `Olá! Tenho interesse em ${whatsappContext}.`
);

const imageColClass =
  heroImageScale === 'large'
    ? 'mx-auto w-full max-w-xl sm:max-w-2xl lg:mx-0 lg:max-w-none'
    : 'w-full';
---

<BaseLayout {title} {description} image={ogImage} {ogImageAlt} jsonLdExtra={jsonLdExtra}>
  <PageBreadcrumbs items={breadcrumbs} />
  <article class="bela-section bela-section-muted py-10 md:py-14 lg:py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <!-- Hero alinhado a /servicos: foto à esquerda no desktop; no mobile, texto primeiro -->
      <section
        class="mb-12 scroll-mt-28 md:mb-14"
        aria-labelledby="produto-titulo-principal"
      >
        <div class="grid items-center gap-10 lg:grid-cols-2">
          <div class:list={['order-2 lg:order-1', imageColClass]}>
            <div
              class="bela-surface-card group relative aspect-[4/3] w-full overflow-hidden !rounded-2xl !p-0 shadow-bela"
            >
              <img
                src={heroImage}
                alt={heroImageAlt}
                class:list={[
                  'absolute inset-0 h-full w-full transition-transform duration-500 group-hover:scale-[1.03]',
                  heroImageObjectFit === 'contain'
                    ? 'object-contain object-center'
                    : [
                        'object-cover',
                        heroImageObjectPosition === 'top' ? 'object-top' : 'object-center',
                      ],
                ]}
                width="1200"
                height="900"
                loading="eager"
                decoding="async"
                fetchpriority="high"
              />
            </div>
          </div>
          <div class="order-1 text-center lg:order-2 lg:text-left">
            <p class="mb-3 text-xs font-semibold uppercase tracking-[0.22em] text-rose-300/85">
              Chinelos da Bela
            </p>
            <h1
              id="produto-titulo-principal"
              class="text-3xl font-bold leading-tight text-white sm:text-4xl lg:text-[2.35rem] xl:text-5xl"
            >
              {h1}
            </h1>
            <span
              class="mx-auto mt-5 block h-1 w-14 max-w-full rounded-full bg-gradient-to-r from-rose-500 via-rose-400 to-indigo-400 lg:mx-0"
              aria-hidden="true"
            ></span>
            <div class="mt-6 space-y-4 text-base leading-relaxed text-zinc-400 sm:text-lg">
              {
                Array.isArray(intro) ? (
                  intro.map((t) => <p>{t}</p>)
                ) : (
                  <p>{intro}</p>
                )
              }
            </div>
            <p class="mt-6">
              <a
                href={wa}
                target="_blank"
                rel="noopener noreferrer"
                class="bela-cta-pulse-whatsapp inline-flex min-h-[48px] items-center gap-2 rounded-full bg-[#25D366] px-8 font-semibold text-white transition-colors hover:bg-[#20bd5a]"
                aria-label={`Solicitar orçamento de ${whatsappContext} pelo WhatsApp`}
              >
                <i class="fab fa-whatsapp text-xl" aria-hidden="true"></i>
                Solicitar orçamento
              </a>
            </p>
          </div>
        </div>
      </section>

      <div class="prose prose-invert prose-zinc max-w-none space-y-12">
        {
          beforeSectionsParagraphs.length > 0 && (
            <div
              class="mx-auto max-w-3xl space-y-4 text-base leading-relaxed text-zinc-400"
              role="region"
              aria-label="Introdução ao conteúdo"
            >
              {beforeSectionsParagraphs.map((t) => (
                <p>{t}</p>
              ))}
            </div>
          )
        }
        {
          sections.map((s, idx) => (
            <section class="border-t border-white/[0.08] pt-10 first:border-0 first:pt-0" aria-labelledby={`sec-${idx}`}>
              <h2 id={`sec-${idx}`} class="mb-4 text-2xl font-bold text-white md:text-3xl">
                {s.heading}
              </h2>
              <div class="space-y-4 text-zinc-400 leading-relaxed">
                {s.bodyBlocks && s.bodyBlocks.length > 0 ? (
                  s.bodyBlocks.map((b) =>
                    b.type === 'p' ? (
                      <p>{b.text}</p>
                    ) : (
                      <ul class="list-disc space-y-2 pl-5 marker:text-rose-400/90">
                        {b.items.map((item) => (
                          <li>{item}</li>
                        ))}
                      </ul>
                    )
                  )
                ) : (
                  <>
                    {(s.paragraphs ?? []).map((p) => (
                      <p>{p}</p>
                    ))}
                    {s.bulletList && s.bulletList.length > 0 && (
                      <ul class="list-disc space-y-2 pl-5 marker:text-rose-400/90">
                        {s.bulletList.map((item) => (
                          <li>{item}</li>
                        ))}
                      </ul>
                    )}
                    {(s.paragraphsAfterList ?? []).map((p) => (
                      <p>{p}</p>
                    ))}
                  </>
                )}
                {s.showRoseOrcamentoButton && (
                  <p class="!mt-8 flex justify-center">
                    <a
                      href={wa}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="bela-cta-pulse-rose inline-flex min-h-[52px] items-center justify-center gap-2 rounded-full bg-rose-600 px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-rose-900/40 transition hover:bg-rose-500"
                      aria-label={`Solicitar orçamento de ${whatsappContext} pelo WhatsApp`}
                    >
                      <i class="fab fa-whatsapp text-xl" aria-hidden="true"></i>
                      Solicitar orçamento
                    </a>
                  </p>
                )}
              </div>
            </section>
          ))
        }
      </div>

      {
        productCardsCurrentHref && (
          <ProdutoCardsGrid
            currentHref={productCardsCurrentHref}
            id="linhas-havaianas-personalizadas"
            heading="Havaianas personalizadas por tipo de evento"
            intro="Escolha outra linha ou confira detalhes: o mesmo padrão Chinelos da Bela com Havaianas originais e estampa no solado."
          />
        )
      }

      {
        related.length > 0 && !productCardsCurrentHref && (
          <nav
            class="mt-14 border-t border-white/[0.08] pt-10"
            aria-label="Outras linhas de produtos"
          >
            <h2 class="mb-4 text-xl font-bold text-white md:text-2xl">Outras linhas</h2>
            <ul class="flex flex-wrap gap-3">
              {related.map((r) => (
                <li>
                  <a
                    href={r.href}
                    class="inline-flex min-h-[44px] items-center rounded-full border border-white/15 bg-white/[0.04] px-4 py-2 text-sm font-medium text-rose-200/90 transition-colors hover:border-rose-400/40 hover:bg-white/[0.07] hover:text-rose-100"
                  >
                    {r.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }
    </div>
  </article>
</BaseLayout>
