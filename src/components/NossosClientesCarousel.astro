---
import { depoimentosClientesBela } from '../data/depoimentos-clientes-bela';

const slides = depoimentosClientesBela;
const carouselId = 'bela-depoimentos-carousel';
---

<div class="bela-clientes-carousel mx-auto max-w-5xl" data-bela-carousel={carouselId}>
  <p class="sr-only">
    Carrossel de depoimentos: clique numa foto ou use os controles para ver cada depoimento.
  </p>

  <div class="grid grid-cols-4 gap-2 sm:gap-3 md:gap-5">
    {
      slides.map((s, i) => (
        <button
          type="button"
          class:list={[
            'bela-carousel-thumb group relative aspect-[2/3] w-full overflow-hidden rounded-xl bg-zinc-950 text-left transition-shadow focus:outline-none focus-visible:ring-2 focus-visible:ring-[#ff3465] focus-visible:ring-offset-2 focus-visible:ring-offset-[#111116]',
            'border-2 border-white/10',
            i === 0 && 'bela-carousel-thumb--active',
          ]}
          data-bela-thumb={i}
          aria-label={`Ver depoimento ${i + 1} de ${slides.length}: ${s.author}`}
          aria-pressed={i === 0 ? 'true' : 'false'}
        >
          <span class="pointer-events-none absolute inset-0 block overflow-hidden">
            <img
              src={s.photo}
              alt={s.photoAlt}
              class="absolute top-0 h-full w-[400%] max-w-none object-cover object-center transition-transform duration-300 group-hover:scale-[1.02]"
              style={`left: ${-s.stripIndex * 100}%`}
              loading={i < 2 ? 'eager' : 'lazy'}
              decoding="async"
            />
          </span>
        </button>
      ))
    }
  </div>

  <div
    class="relative mt-6 overflow-hidden rounded-2xl border border-white/10 bg-zinc-900/40 shadow-xl sm:mt-8"
    aria-live="polite"
  >
    <div class="bela-carousel-slides relative min-h-[12rem] w-full sm:min-h-[11rem] md:min-h-[10rem]">
      {
        slides.map((s, i) => (
          <article
            class:list={[
              'bela-carousel-slide flex w-full flex-col px-5 py-6 transition-opacity duration-500 ease-out sm:px-8 sm:py-8',
              i === 0 ? 'relative z-10 opacity-100' : 'pointer-events-none absolute inset-0 z-0 opacity-0',
            ]}
            data-bela-slide={i}
            hidden={i !== 0}
          >
            <div class="flex gap-1" aria-hidden="true">
              {[0, 1, 2, 3, 4].map((k) => (
                <span
                  class:list={[
                    'inline-flex h-2 w-2 rounded-full',
                    k < 4 ? 'bg-[#7ec8c3]' : 'bg-white/20',
                  ]}
                />
              ))}
            </div>
            <blockquote class="m-0 mt-4">
              <p class="text-base font-medium leading-relaxed text-zinc-100 sm:text-lg md:text-xl">
                &ldquo;{s.text}&rdquo;
              </p>
              <footer class="mt-5 text-sm font-semibold text-[#ff6b8a] md:text-base">&mdash; {s.author}</footer>
            </blockquote>
          </article>
        ))
      }
    </div>
  </div>

  <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
    <button
      type="button"
      class="bela-carousel-prev inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full border border-white/20 text-white transition-colors hover:border-[#ff3465]/70 hover:text-[#ff3465]"
      aria-label="Depoimento anterior"
    >
      <span class="text-xl leading-none" aria-hidden="true">‹</span>
    </button>
    <div class="flex gap-2" role="tablist" aria-label="Selecionar depoimento">
      {
        slides.map((_, i) => (
          <button
            type="button"
            role="tab"
            class:list={['bela-carousel-dot h-2.5 w-2.5 rounded-full transition-colors', i === 0 && 'is-active']}
            data-bela-dot={i}
            aria-label={`Depoimento ${i + 1}`}
            aria-selected={i === 0 ? 'true' : 'false'}
          />
        ))
      }
    </div>
    <button
      type="button"
      class="bela-carousel-next inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-full border border-white/20 text-white transition-colors hover:border-[#ff3465]/70 hover:text-[#ff3465]"
      aria-label="Próximo depoimento"
    >
      <span class="text-xl leading-none" aria-hidden="true">›</span>
    </button>
  </div>
</div>

<style>
  .bela-carousel-slides {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: 1fr;
    align-items: stretch;
  }

  .bela-carousel-thumb--active {
    box-shadow: 0 0 0 3px #ff3465;
    border-color: rgba(253, 164, 184, 0.6);
  }

  .bela-carousel-dot {
    background-color: rgba(255, 255, 255, 0.28);
  }

  .bela-carousel-dot:hover {
    background-color: rgba(255, 255, 255, 0.45);
  }

  .bela-carousel-dot.is-active {
    background-color: #ff3465;
  }

  .bela-carousel-dot.is-active:hover {
    background-color: #ff5c7c;
  }
</style>

<script define:vars={{ total: slides.length, carouselId }}>
  function initCarousel(root) {
    const thumbs = [...root.querySelectorAll('[data-bela-thumb]')];
    const slideEls = [...root.querySelectorAll('[data-bela-slide]')];
    const dots = [...root.querySelectorAll('[data-bela-dot]')];
    const prev = root.querySelector('.bela-carousel-prev');
    const next = root.querySelector('.bela-carousel-next');

    let active = 0;
    let timer = null;
    const intervalMs = 7000;

    function apply(i) {
      active = ((i % total) + total) % total;
      slideEls.forEach((el, j) => {
        const on = j === active;
        el.hidden = !on;
        el.classList.toggle('relative', on);
        el.classList.toggle('z-10', on);
        el.classList.toggle('opacity-100', on);
        el.classList.toggle('absolute', !on);
        el.classList.toggle('inset-0', !on);
        el.classList.toggle('z-0', !on);
        el.classList.toggle('opacity-0', !on);
        el.classList.toggle('pointer-events-none', !on);
      });
      thumbs.forEach((btn, j) => {
        const on = j === active;
        btn.classList.toggle('bela-carousel-thumb--active', on);
        btn.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
      dots.forEach((dot, j) => {
        const on = j === active;
        dot.classList.toggle('is-active', on);
        dot.setAttribute('aria-selected', on ? 'true' : 'false');
      });
    }

    function go(delta) {
      apply(active + delta);
    }

    function startAutoplay() {
      stopAutoplay();
      timer = window.setInterval(() => go(1), intervalMs);
    }

    function stopAutoplay() {
      if (timer != null) {
        clearInterval(timer);
        timer = null;
      }
    }

    thumbs.forEach((btn, j) => {
      btn.addEventListener('click', () => {
        apply(j);
        startAutoplay();
      });
    });

    dots.forEach((dot, j) => {
      dot.addEventListener('click', () => {
        apply(j);
        startAutoplay();
      });
    });

    prev?.addEventListener('click', () => {
      go(-1);
      startAutoplay();
    });

    next?.addEventListener('click', () => {
      go(1);
      startAutoplay();
    });

    root.addEventListener('mouseenter', stopAutoplay);
    root.addEventListener('mouseleave', startAutoplay);
    root.addEventListener('focusin', stopAutoplay);
    root.addEventListener('focusout', (e) => {
      const rt = e.relatedTarget;
      if (rt instanceof Node && root.contains(rt)) return;
      startAutoplay();
    });

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stopAutoplay();
      else startAutoplay();
    });

    startAutoplay();
  }

  document.querySelectorAll(`[data-bela-carousel="${carouselId}"]`).forEach((el) => {
    if (el instanceof HTMLElement) initCarousel(el);
  });
</script>
