---
import { siteConfig, whatsappHref } from '../config';
import SocialIcons from './SocialIcons.astro';
---

<footer
  class="relative z-[1] mt-auto border-t border-white/[0.08] bg-[#111116] text-zinc-300"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <div>
        <a href="/" class="inline-block mb-4 min-h-[44px]">
          <img
            src={siteConfig.images.logoWhite}
            alt={siteConfig.name}
            class="h-10 w-auto max-w-[220px] object-contain object-left"
            width="220"
            height="40"
            loading="lazy"
          />
        </a>
        <p class="text-sm text-zinc-400 mb-4 max-w-sm leading-relaxed">
          Havaianas Personalizadas Chinelos da Bela — casamento, formatura, 15 anos e brindes corporativos, com Havaianas
          originais e estampa no solado.
        </p>
        <p class="text-xs text-zinc-500">CNPJ {siteConfig.cnpj}</p>
      </div>
      <div>
        <h3 class="font-display font-semibold text-white mb-4 text-sm uppercase tracking-wide">Mapa do site</h3>
        <ul class="space-y-1">
          {
            siteConfig.footerNav.map((item) => (
              <li>
                <a href={item.href} class="text-zinc-400 hover:text-rose-300 transition-colors min-h-[44px] inline-flex items-center text-sm leading-snug">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <h3 class="font-display font-semibold text-white mb-4 text-sm uppercase tracking-wide">Contato</h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a
              href={whatsappHref(siteConfig.whatsappPhone)}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex min-h-[44px] items-center gap-2 font-medium text-[#25D366]"
            >
              <i class="fab fa-whatsapp" aria-hidden="true"></i>
              WhatsApp
            </a>
          </li>
          <li>
            <a href={`mailto:${siteConfig.email}`} class="break-all text-zinc-400 hover:text-rose-300">
              {siteConfig.email}
            </a>
          </li>
        </ul>
        <h3 class="font-display mb-3 mt-6 text-sm font-semibold uppercase tracking-wide text-white">Redes sociais</h3>
        <SocialIcons />
      </div>
      <div>
        <h3 class="font-display font-semibold text-white mb-4 text-sm uppercase tracking-wide">Endereço</h3>
        <p class="text-sm text-zinc-400 leading-relaxed mb-4">{siteConfig.address}</p>
        <a
          href={siteConfig.mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-rose-300 hover:text-rose-200 text-sm font-medium min-h-[44px] inline-flex items-center"
        >
          Ver no mapa
        </a>
      </div>
    </div>
    <p class="mt-12 pt-8 border-t border-white/10 text-center text-xs text-zinc-600">
      © {new Date().getFullYear()} {siteConfig.name}. Havaianas Personalizadas.
    </p>
  </div>
</footer>
